{
  "$schema": "https://schemas.starfox.app/design-tokens/v1",
  "name": "Horizon",
  "description": "Design tokens for StarFox / Horizon — an arcade flight game. Atmosphere-first palette: warm sunset sky, cool silhouettes, off-white ink, ember/flare accents.",
  "color": {
    "sky": {
      "deep":  { "value": "#2a1a3a", "description": "Top of dusk gradient (deep plum)" },
      "plum":  { "value": "#7a3a4a", "description": "Upper-mid sky" },
      "ember": { "value": "#d2603a", "description": "Mid sky, near horizon" },
      "flare": { "value": "#f59045", "description": "Horizon glow" },
      "haze":  { "value": "#fcd793", "description": "Bottom haze, sun-side" }
    },
    "silhouette": {
      "far":   { "value": "#5a2838" },
      "mid":   { "value": "#3a1e2a" },
      "near":  { "value": "#2a1820" },
      "ridge": { "value": "#1a0e1c" },
      "void":  { "value": "#0a0612", "description": "Page background" }
    },
    "ink": {
      "bone":  { "value": "#fff5e8", "description": "Primary text" },
      "haze":  { "value": "#f5d8a8", "description": "Eyebrow, italic taglines" },
      "dim":   { "value": "rgba(255,245,232,0.65)", "description": "Secondary text, labels" },
      "ghost": { "value": "rgba(255,245,232,0.35)", "description": "Disabled, hint" }
    },
    "accent": {
      "ember":      { "value": "#ffb347", "description": "Multiplier ≥ 2, achievements, NEW RECORD" },
      "flare":      { "value": "#ff6a1a", "description": "Active lock-on, engine glow" },
      "core":       { "value": "#fff5d0", "description": "Sun disc, hotspot highlights" },
      "shieldCyan": { "value": "#7adfd0", "description": "Shield-charge state" },
      "warn":       { "value": "#ff5566", "description": "Low shield, error" }
    }
  },
  "typography": {
    "fonts": {
      "display": { "family": "Inter Tight", "fallback": "system-ui, sans-serif", "weights": [200, 300, 400, 500], "italics": [300, 400] },
      "mono":    { "family": "JetBrains Mono", "fallback": "ui-monospace, monospace", "weights": [300, 400, 500] }
    },
    "scale": {
      "display":    { "font": "display", "size": 88, "weight": 200, "tracking": "-0.04em", "lineHeight": 0.95 },
      "title":      { "font": "display", "size": 42, "weight": 300, "tracking": "-0.02em", "lineHeight": 1.05 },
      "heading":    { "font": "display", "size": 22, "weight": 400, "tracking": "-0.01em", "lineHeight": 1.2 },
      "body":       { "font": "display", "size": 15, "weight": 400, "lineHeight": 1.5 },
      "caption":    { "font": "display", "size": 12, "weight": 400 },
      "label":      { "font": "mono", "size": 11, "weight": 500, "tracking": "0.22em", "transform": "uppercase" },
      "eyebrow":    { "font": "mono", "size": 10, "weight": 500, "tracking": "0.32em", "transform": "uppercase" },
      "readoutXL":  { "font": "mono", "size": 64, "weight": 300, "tracking": "-0.02em", "lineHeight": 1 },
      "readout":    { "font": "mono", "size": 32, "weight": 400, "lineHeight": 1 },
      "telemetry":  { "font": "mono", "size": 13, "weight": 400, "tracking": "0.18em" }
    }
  },
  "spacing": {
    "base": 4,
    "scale": [4, 8, 12, 16, 24, 32, 48, 64]
  },
  "radius": {
    "0": 0, "1": 2, "2": 4, "3": 8, "full": 9999,
    "guidance": "HUD = 0–2 (sharp/instrumented). Menus, cards, buttons = 4. Pills/badges = full."
  },
  "stroke": {
    "hairline": 1, "thin": 1.5, "medium": 2, "bold": 3
  },
  "motion": {
    "easing": {
      "out": "cubic-bezier(0.2, 0.7, 0.2, 1)",
      "in":  "cubic-bezier(0.6, 0, 0.8, 0.4)"
    },
    "duration": { "instant": 80, "fast": 160, "base": 220, "slow": 480 }
  },
  "surface": {
    "panel":    "rgba(10,6,18,0.55)",
    "panelHi":  "rgba(10,6,18,0.60)",
    "hairline": "rgba(255,245,232,0.12)",
    "divider":  "rgba(255,245,232,0.10)",
    "blurGlass": 14,
    "blurPause": 6
  }
}
